---
import { services } from "../../data/site";

const iconMap: Record<string, string> = {
  cleaning: `<path d="M3 21h18M5 21V7l7-4 7 4v14" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><path d="M9 21v-6h6v6" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><path d="M9 9h.01M15 9h.01M9 13h6" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>`,
  maintenance: `<path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>`,
  outsourcing: `<path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="7" r="4" stroke-width="1.2"/><path d="M22 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>`,
  security: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>`,
  pest: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 8v4M12 16h.01" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>`,
  garden: `<path d="M17 8c.7-1 1-2.2 1-3.5 0-.3 0-.7-.1-1C14.6 3.8 12 6 12 9c0-3-2.6-5.2-5.9-4.5-.1.3-.1.7-.1 1C6 6.8 6.3 8 7 9" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 9v13M12 9c-2 3-6 4-6 9M12 9c2 3 6 4 6 9" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>`,
  project: `<rect x="3" y="3" width="18" height="18" rx="2" stroke-width="1.2"/><path d="M3 9h18M9 21V9" stroke-width="1.2" stroke-linecap="round"/><path d="M13 13h4M13 17h2" stroke-width="1.2" stroke-linecap="round"/>`,
  waste: `<path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 11l-4 6M10 11l4 6" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>`,
  geriatric: `<path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="7" r="4" stroke-width="1.2"/><path d="M20 8v6M17 11h6" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>`,
};
---

<section id="servicios" class="py-24 lg:py-32 bg-ivory">
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="lg:flex lg:justify-between lg:items-end gap-12 mb-16" data-animate>
      <div class="max-w-xl">
        <p class="text-[11px] font-bold uppercase tracking-[0.25em] text-mf-blue/70 mb-4">Servicios</p>
        <h2 class="font-[family-name:var(--font-display)] text-3xl lg:text-[2.75rem] font-extrabold text-slate-deep leading-[1.12]">
          Lo que hacemos por su operación
        </h2>
      </div>
      <p class="text-slate-mid max-w-sm text-[15px] leading-relaxed mt-4 lg:mt-0">{services.subtitle}</p>
    </div>

    <!-- Featured service + list layout (NOT uniform cards) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6" data-animate>
      <!-- Featured: first 3 services as large cards -->
      <div class="lg:col-span-5 grid grid-cols-1 gap-4">
        {services.items.slice(0, 3).map((item, i) => (
          <div class="bg-white rounded-[1.25rem] p-8 border border-black/[0.04] hover-lift">
            <div class={`w-11 h-11 rounded-xl flex items-center justify-center mb-6 ${i % 2 === 0 ? "bg-mf-green/[0.06] border border-mf-green/[0.1]" : "bg-mf-blue/[0.06] border border-mf-blue/[0.1]"}`}>
              <svg class={`w-5 h-5 ${i % 2 === 0 ? "text-mf-green" : "text-mf-blue"}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={iconMap[item.icon]} />
              </svg>
            </div>
            <h3 class="font-[family-name:var(--font-display)] text-xl font-bold text-slate-deep mb-3">{item.title}</h3>
            <p class="text-slate-soft text-sm leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>

      <!-- Right: compact list for remaining services -->
      <div class="lg:col-span-7 bg-white rounded-[1.25rem] border border-black/[0.04] overflow-hidden">
        {services.items.slice(3).map((item, i) => (
          <div class={`flex items-start gap-4 px-7 py-5 hover:bg-ivory/80 transition-colors ${i < services.items.slice(3).length - 1 ? "border-b border-black/[0.04]" : ""}`}>
            <div class={`w-9 h-9 rounded-lg flex items-center justify-center shrink-0 mt-0.5 ${i % 2 === 0 ? "bg-mf-green/[0.06]" : "bg-mf-blue/[0.06]"}`}>
              <svg class={`w-4 h-4 ${i % 2 === 0 ? "text-mf-green" : "text-mf-blue"}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={iconMap[item.icon]} />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-slate-deep text-[15px] mb-0.5">{item.title}</h3>
              <p class="text-slate-soft text-xs leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
