---
import { valueChain } from "../../data/site";
---

<!-- Horizontal trust strip — not a full section, just a visual break -->
<section class="py-16 lg:py-20 bg-ivory border-y border-black/[0.04]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" data-animate>
    <div class="flex flex-col lg:flex-row lg:items-center gap-10">
      <div class="lg:w-2/5">
        <h3 class="font-[family-name:var(--font-display)] text-2xl font-extrabold text-slate-deep mb-2">Lo que nos diferencia</h3>
        <p class="text-slate-soft text-sm">Resultados medibles para su operación.</p>
      </div>
      <div class="lg:w-3/5 flex flex-wrap gap-3">
        {[
          "Ahorro de tiempo y recursos",
          "Mayor productividad",
          "Imagen empresarial",
          "Tranquilidad operativa",
          "Espacios funcionales",
          ...valueChain.items,
        ].map((item) => (
          <span class="bg-white text-slate-deep text-sm font-medium px-5 py-2.5 rounded-full border border-black/[0.06]">
            {item}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
