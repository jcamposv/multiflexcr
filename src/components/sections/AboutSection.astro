---
import { about } from "../../data/site";
---

<section id="nosotros" class="py-24 lg:py-32 bg-green-wash">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- About - asymmetric editorial -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center mb-28" data-animate>
      <div class="lg:col-span-5 relative">
        <div class="rounded-[1.5rem] overflow-hidden">
          <img src="/edificio.jpg" alt="Edificio corporativo" class="w-full aspect-[3/4] object-cover" />
        </div>
        <div class="absolute -bottom-6 right-4 bg-white rounded-2xl shadow-xl shadow-black/[0.08] px-6 py-5 border border-black/[0.04]">
          <div class="text-4xl font-extrabold font-[family-name:var(--font-display)] text-mf-green leading-none">20+</div>
          <div class="text-xs text-slate-mid font-medium mt-1">Años liderando operaciones</div>
        </div>
      </div>

      <div class="lg:col-span-7">
        <p class="text-[11px] font-bold uppercase tracking-[0.25em] text-mf-green/70 mb-5">Sobre nosotros</p>
        <h2 class="font-[family-name:var(--font-display)] text-3xl lg:text-[2.75rem] font-extrabold text-slate-deep leading-[1.12] mb-6">
          Excelencia en servicios<br class="hidden lg:block"/> integrales
        </h2>
        <p class="text-slate-mid leading-[1.75] mb-4 text-[15px]">{about.description}</p>
        <p class="text-slate-soft text-sm leading-relaxed mb-8">{about.subdescription}</p>

        <!-- Misión & Visión inline, not as cards -->
        <div class="grid grid-cols-2 gap-8 pt-8 border-t border-black/[0.06]">
          <div>
            <h3 class="font-[family-name:var(--font-display)] text-lg font-bold text-slate-deep mb-2">{about.mision.title}</h3>
            <p class="text-slate-soft text-sm leading-relaxed">{about.mision.text}</p>
          </div>
          <div>
            <h3 class="font-[family-name:var(--font-display)] text-lg font-bold text-slate-deep mb-2">{about.vision.title}</h3>
            <p class="text-slate-soft text-sm leading-relaxed">{about.vision.text}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Valores - horizontal editorial, not numbered cards -->
    <div data-animate>
      <div class="lg:flex lg:gap-16 lg:items-start">
        <div class="lg:w-1/3 lg:sticky lg:top-32 mb-10 lg:mb-0">
          <h3 class="font-[family-name:var(--font-display)] text-2xl lg:text-3xl font-extrabold text-slate-deep mb-3">Nuestros<br/>Valores</h3>
          <p class="text-slate-soft text-sm leading-relaxed">Los principios que guían cada operación y relación con nuestros clientes.</p>
        </div>
        <div class="lg:w-2/3">
          {about.valores.map((v, i) => (
            <div class={`flex gap-6 py-7 ${i < about.valores.length - 1 ? "border-b border-black/[0.06]" : ""}`}>
              <span class="text-[11px] font-bold text-mf-green/40 mt-1 shrink-0 w-6">0{i + 1}</span>
              <div>
                <h4 class="font-[family-name:var(--font-display)] font-bold text-slate-deep mb-1">{v.title}</h4>
                <p class="text-slate-soft text-sm leading-relaxed">{v.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
