---
import { process } from "../../data/site";
---

<section id="proceso" class="py-24 lg:py-32 bg-blue-wash">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Full-width dark banner with process -->
    <div class="bg-mf-blue-deeper rounded-[1.5rem] overflow-hidden" data-animate>
      <div class="grid grid-cols-1 lg:grid-cols-2">
        <!-- Left: process steps -->
        <div class="p-8 lg:p-12">
          <p class="text-[11px] font-bold uppercase tracking-[0.25em] text-mf-green-light/60 mb-4">Proceso</p>
          <h2 class="font-[family-name:var(--font-display)] text-3xl lg:text-4xl font-extrabold text-white leading-[1.12] mb-10">
            {process.headline}
          </h2>

          {process.steps.map((step, i) => (
            <div class={`flex gap-5 py-5 ${i < 3 ? "border-b border-white/[0.06]" : ""}`}>
              <span class="text-mf-green-light font-[family-name:var(--font-display)] font-bold text-lg w-8 shrink-0">{step.number}</span>
              <div>
                <h3 class="font-semibold text-white mb-1 text-[15px]">{step.title}</h3>
                <p class="text-white/50 text-sm leading-relaxed">{step.description}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Right: guarantees + image -->
        <div class="bg-white/[0.03] p-8 lg:p-12 flex flex-col justify-between">
          <div>
            <h3 class="font-[family-name:var(--font-display)] text-xl font-bold text-white mb-8">Garantizamos</h3>
            <div class="grid grid-cols-2 gap-x-8 gap-y-6">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-mf-green-light shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path d="M22 7l-8.5 8.5-5-5L2 17" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M16 7h6v6" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="text-white/80 text-sm font-medium">Mejora continua</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-mf-green-light shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path d="M22 11.08V12a10 10 0 11-5.93-9.14" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M22 4L12 14.01l-3-3" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="text-white/80 text-sm font-medium">Calidad en procesos</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-mf-green-light shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M9 12l2 2 4-4" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="text-white/80 text-sm font-medium">Seguridad operativa</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-mf-green-light shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <rect x="3" y="3" width="18" height="18" rx="2" stroke-width="1.2"/>
                  <path d="M3 9h18M9 21V9" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                <span class="text-white/80 text-sm font-medium">Control SLA y KPIs</span>
              </div>
            </div>
          </div>

          <!-- Ciclo de proceso visual -->
          <div class="mt-8 flex justify-center">
            <img src="/proceso-ciclo.svg" alt="Ciclo de trabajo: Diagnóstico, Propuesta, Ejecución y Supervisión" class="w-full max-w-md opacity-90" />
          </div>

          <div class="mt-10 pt-6 border-t border-white/[0.06] flex flex-wrap items-center gap-3">
            <span class="text-[10px] uppercase tracking-widest text-white/30 font-bold mr-2">Normas</span>
            <span class="text-white/50 text-xs font-medium px-3 py-1 rounded-full border border-white/[0.08]">ISO 9001</span>
            <span class="text-white/50 text-xs font-medium px-3 py-1 rounded-full border border-white/[0.08]">ISO 14001</span>
            <span class="text-white/50 text-xs font-medium px-3 py-1 rounded-full border border-white/[0.08]">ISO 45001</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
