---
import { contact } from "../../data/site";
---

<section id="contacto" class="py-24 lg:py-32 bg-blue-wash">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
            <!-- Left info -->
            <div class="lg:col-span-2" data-animate>
                <p
                    class="text-[11px] font-bold uppercase tracking-[0.25em] text-mf-green/70 mb-4"
                >
                    Contacto
                </p>
                <h2
                    class="font-[family-name:var(--font-display)] font-extrabold text-3xl lg:text-4xl text-slate-deep leading-[1.1] mb-4"
                >
                    {contact.headline}
                </h2>
                <p class="text-slate-mid leading-relaxed text-[15px] mb-10">
                    {contact.description}
                </p>

                <div class="space-y-6">
                    <div class="flex items-start gap-4">
                        <div
                            class="w-10 h-10 rounded-xl bg-white flex items-center justify-center shrink-0 border border-black/[0.06]"
                        >
                            <svg
                                class="w-5 h-5 text-mf-blue"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <rect
                                    x="2"
                                    y="4"
                                    width="20"
                                    height="16"
                                    rx="2"
                                    stroke-width="1.2"></rect>
                                <path
                                    d="M22 7l-10 6L2 7"
                                    stroke-width="1.2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"></path>
                            </svg>
                        </div>
                        <div>
                            <div
                                class="font-semibold text-slate-deep text-sm mb-1"
                            >
                                Correo
                            </div>
                            <a
                                href="mailto:khenry@multiflexcr.com"
                                class="text-slate-mid hover:text-mf-green text-sm transition-colors block"
                                >khenry@multiflexcr.com</a
                            >
                            <a
                                href="mailto:ventas@multiflex.com"
                                class="text-slate-mid hover:text-mf-green text-sm transition-colors block"
                                >ventas@multiflex.com</a
                            >
                        </div>
                    </div>

                    <div class="flex items-start gap-4">
                        <div
                            class="w-10 h-10 rounded-xl bg-white flex items-center justify-center shrink-0 border border-black/[0.06]"
                        >
                            <svg
                                class="w-5 h-5 text-mf-green"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"
                                    stroke-width="1.2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"></path>
                            </svg>
                        </div>
                        <div>
                            <div
                                class="font-semibold text-slate-deep text-sm mb-1"
                            >
                                Teléfono
                            </div>
                            <div class="text-slate-mid text-sm">
                                Kevin Henry: 6037-4348
                            </div>
                            <div class="text-slate-mid text-sm">
                                Verónica Castro: 8464-6200
                            </div>
                        </div>
                    </div>

                    <div class="flex items-start gap-4">
                        <div
                            class="w-10 h-10 rounded-xl bg-white flex items-center justify-center shrink-0 border border-black/[0.06]"
                        >
                            <svg
                                class="w-5 h-5 text-mf-blue"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <circle
                                    cx="12"
                                    cy="12"
                                    r="10"
                                    stroke-width="1.2"></circle>
                                <path
                                    d="M12 6v6l4 2"
                                    stroke-width="1.2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"></path>
                            </svg>
                        </div>
                        <div>
                            <div
                                class="font-semibold text-slate-deep text-sm mb-1"
                            >
                                Horario
                            </div>
                            <div class="text-slate-mid text-sm">
                                Lunes a Viernes
                            </div>
                            <div class="text-slate-mid text-sm">
                                8:00 AM - 5:00 PM
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right form -->
            <div class="lg:col-span-3" data-animate>
                <div
                    class="bg-white rounded-[1.5rem] p-8 lg:p-10 border border-black/[0.04] shadow-[0_4px_40px_-12px_rgba(0,0,0,0.08)]"
                >
                    <form
                        id="contact-form"
                        action="https://formsubmit.co/khenry@multiflexcr.com"
                        method="POST"
                        class="space-y-5"
                    >
                        <input
                            type="hidden"
                            name="_subject"
                            value="Nueva solicitud de contacto — Multiflex Web"
                        />
                        <input type="hidden" name="_captcha" value="false" />
                        <input type="hidden" name="_template" value="table" />
                        <input
                            type="hidden"
                            name="_next"
                            value="https://www.multiflexcr.com/#contacto"
                        />
                        <input type="text" name="_honey" style="display:none" />
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label
                                    for="nombre"
                                    class="block text-xs font-semibold text-slate-deep mb-2 uppercase tracking-wider"
                                    >Nombre *</label
                                >
                                <input
                                    type="text"
                                    id="nombre"
                                    name="nombre"
                                    required
                                    class="w-full px-4 py-3.5 rounded-xl border border-black/[0.08] bg-ivory text-slate-deep text-sm focus:outline-none focus:ring-2 focus:ring-mf-green/20 focus:border-mf-green/40 transition-all placeholder:text-slate-soft/60"
                                    placeholder="Su nombre"
                                />
                            </div>
                            <div>
                                <label
                                    for="apellido"
                                    class="block text-xs font-semibold text-slate-deep mb-2 uppercase tracking-wider"
                                    >Apellido *</label
                                >
                                <input
                                    type="text"
                                    id="apellido"
                                    name="apellido"
                                    required
                                    class="w-full px-4 py-3.5 rounded-xl border border-black/[0.08] bg-ivory text-slate-deep text-sm focus:outline-none focus:ring-2 focus:ring-mf-green/20 focus:border-mf-green/40 transition-all placeholder:text-slate-soft/60"
                                    placeholder="Su apellido"
                                />
                            </div>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label
                                    for="empresa"
                                    class="block text-xs font-semibold text-slate-deep mb-2 uppercase tracking-wider"
                                    >Empresa</label
                                >
                                <input
                                    type="text"
                                    id="empresa"
                                    name="empresa"
                                    class="w-full px-4 py-3.5 rounded-xl border border-black/[0.08] bg-ivory text-slate-deep text-sm focus:outline-none focus:ring-2 focus:ring-mf-green/20 focus:border-mf-green/40 transition-all placeholder:text-slate-soft/60"
                                    placeholder="Nombre de su empresa"
                                />
                            </div>
                            <div>
                                <label
                                    for="telefono"
                                    class="block text-xs font-semibold text-slate-deep mb-2 uppercase tracking-wider"
                                    >Teléfono</label
                                >
                                <input
                                    type="tel"
                                    id="telefono"
                                    name="telefono"
                                    class="w-full px-4 py-3.5 rounded-xl border border-black/[0.08] bg-ivory text-slate-deep text-sm focus:outline-none focus:ring-2 focus:ring-mf-green/20 focus:border-mf-green/40 transition-all placeholder:text-slate-soft/60"
                                    placeholder="+506 0000-0000"
                                />
                            </div>
                        </div>

                        <div>
                            <label
                                for="email"
                                class="block text-xs font-semibold text-slate-deep mb-2 uppercase tracking-wider"
                                >Correo electrónico *</label
                            >
                            <input
                                type="email"
                                id="email"
                                name="email"
                                required
                                class="w-full px-4 py-3.5 rounded-xl border border-black/[0.08] bg-ivory text-slate-deep text-sm focus:outline-none focus:ring-2 focus:ring-mf-green/20 focus:border-mf-green/40 transition-all placeholder:text-slate-soft/60"
                                placeholder="correo@ejemplo.com"
                            />
                        </div>

                        <div>
                            <label
                                for="servicio"
                                class="block text-xs font-semibold text-slate-deep mb-2 uppercase tracking-wider"
                                >Servicio de interés</label
                            >
                            <select
                                id="servicio"
                                name="servicio"
                                class="w-full px-4 py-3.5 rounded-xl border border-black/[0.08] bg-ivory text-slate-deep text-sm focus:outline-none focus:ring-2 focus:ring-mf-green/20 focus:border-mf-green/40 transition-all"
                            >
                                <option value="">Seleccione un servicio</option>
                                <option value="limpieza"
                                    >Servicios de Limpieza</option
                                >
                                <option value="mantenimiento"
                                    >Mantenimiento</option
                                >
                                <option value="outsourcing">Outsourcing</option>
                                <option value="seguridad"
                                    >Servicios de Seguridad</option
                                >
                                <option value="plagas">Control de Plagas</option
                                >
                                <option value="jardineria">Jardinería</option>
                                <option value="proyectos"
                                    >Gestión de Proyectos</option
                                >
                                <option value="residuos"
                                    >Administración y Gestión de Residuos</option
                                >
                                <option value="geriatria"
                                    >Asistencia de Pacientes Geriátricos</option
                                >
                                <option value="varios">Varios servicios</option>
                            </select>
                        </div>

                        <div>
                            <label
                                for="mensaje"
                                class="block text-xs font-semibold text-slate-deep mb-2 uppercase tracking-wider"
                                >Mensaje *</label
                            >
                            <textarea
                                id="mensaje"
                                name="mensaje"
                                rows="4"
                                required
                                class="w-full px-4 py-3.5 rounded-xl border border-black/[0.08] bg-ivory text-slate-deep text-sm focus:outline-none focus:ring-2 focus:ring-mf-green/20 focus:border-mf-green/40 transition-all resize-none placeholder:text-slate-soft/60"
                                placeholder="Describa brevemente lo que necesita..."
                            ></textarea>
                        </div>

                        <button
                            type="submit"
                            class="w-full bg-slate-deep hover:bg-mf-blue-deeper text-white font-medium rounded-xl px-7 py-4 text-sm transition-all cursor-pointer flex items-center justify-center gap-2"
                        >
                            Enviar solicitud
                            <svg
                                class="w-4 h-4"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"
                                ></path></svg
                            >
                        </button>
                    </form>

                    <div id="form-success" class="hidden text-center py-10">
                        <div
                            class="w-14 h-14 rounded-2xl bg-mf-green/[0.06] border border-mf-green/[0.1] flex items-center justify-center mx-auto mb-4"
                        >
                            <svg
                                class="w-6 h-6 text-mf-green"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    d="M22 11.08V12a10 10 0 11-5.93-9.14"
                                    stroke-width="1.2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"></path>
                                <path
                                    d="M22 4L12 14.01l-3-3"
                                    stroke-width="1.2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"></path>
                            </svg>
                        </div>
                        <h4 class="text-xl font-bold text-slate-deep mb-2">
                            Mensaje enviado
                        </h4>
                        <p class="text-slate-mid text-sm">
                            Nos pondremos en contacto con usted a la brevedad
                            posible.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    const form = document.getElementById("contact-form") as HTMLFormElement;
    const success = document.getElementById("form-success") as HTMLElement;
    const submitBtn = form?.querySelector(
        'button[type="submit"]',
    ) as HTMLButtonElement;

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();

        const originalText = submitBtn.innerHTML;
        submitBtn.disabled = true;
        submitBtn.innerHTML = `
      <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
      Enviando...
    `;

        try {
            const res = await fetch(form.action, {
                method: "POST",
                body: new FormData(form),
            });

            if (res.ok) {
                form.classList.add("hidden");
                success.classList.remove("hidden");
            } else {
                alert("Error al enviar el mensaje. Intente de nuevo.");
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
            }
        } catch {
            alert("Error de conexión. Intente de nuevo.");
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
        }
    });
</script>
